{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/stripe-webhook", "destination": "/api/stripe-webhook" },
    { "source": "/shop", "destination": "/index.html" },
    { "source": "/cart", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/success", "destination": "/index.html" },
    { "source": "/impressum", "destination": "/index.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
