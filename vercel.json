{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/api/stripe-webhook", "dest": "/api/stripe-webhook.ts" },
    { "src": "/api/(.*)", "dest": "/api/$1.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html", "headers": { "x-hermes-status": "spa-fallback-active" } }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "x-hermes-deployment", "value": "fix-404-v2" }
      ]
    }
  ]
}
