     9|      "parameters": {
    10|        "jsCode": "// 🔍 SCHRITT 1: Reddit Search — liest Config, gibt Config + redditSearchResults weiter\nconst config = $input.first().json;\nconst results = [];\nfor (let i = 0; i < config.redditSearches.length; i++) {\n  const s = config.redditSearches[i];\n  const tf = s.t ? '&t=' + s.t : '';\n  try {\n    const res = await this.helpers.httpRequest({\n      method: 'GET',\n      url: 'https://www.reddit.com/search.rss?q=' + encodeURIComponent(s.q) + '&sort=' + s.sort + tf + '&limit=25',\n      timeout: 12000,\n      headers: { 'User-Agent': 'n8n-deepsearch/3.0' }\n    });\n    const xml = typeof res === 'string' ? res : '';\n    if (xml.length > 100) {\n      const rx = /<entry>([\\s\\S]*?)<\\/entry>/g; let m;\n      while ((m = rx.exec(xml)) !== null) {\n        const b = m[1];\n        const ex = (tag) => { const r = new RegExp('<' + tag + '[^>]*>([\\\\s\\\\S]*?)</' + tag + '>', 'i'); const x = r.exec(b); return x ? x[1].replace(/<[^>]*>/g,'').replace(/&amp;/g,'&').replace(/&lt;/g,'<').replace(/&gt;/g,'>').trim() : ''; };\n        const titel = ex('title'); const inhalt = ex('content') || ex('summary');\n        if (titel && titel.length > 5) results.push({ titel, inhalt: inhalt.substring(0,600), quelleDetail: s.label, typ: 'reddit_search' });\n      }\n    }\n  } catch(e) {}\n  await new Promise(r => setTimeout(r, 600));\n}\nconsole.log('Reddit Search: ' + results.length);\nreturn [{ json: { ...config, alleResults: results } }];"
