    36|        "jsCode": "// 📰 SCHRITT 3: Google News — APPENDED zu alleResults\nconst prev = $input.first().json;\nconst config = prev;\nconst results = [...(prev.alleResults || [])];\nfor (const ns of config.googleNewsSearches) {\n  const lang = ns.hl === 'de' ? '&hl=de&gl=DE&ceid=DE:de' : '&hl=en&gl=US&ceid=US:en';\n  try {\n    const res = await this.helpers.httpRequest({\n      method: 'GET',\n      url: 'https://news.google.com/rss/search?q=' + encodeURIComponent(ns.q) + lang,\n      timeout: 12000,\n      headers: { 'User-Agent': 'n8n-deepsearch/3.0' }\n    });\n    const xml = typeof res === 'string' ? res : '';\n    if (xml.length > 100) {\n      const rx = /<item>([\\s\\S]*?)<\\/item>/g; let m;\n      while ((m = rx.exec(xml)) !== null) {\n        const b = m[1];\n        const ex = (tag) => { const r = new RegExp('<' + tag + '>([\\\\s\\\\S]*?)</' + tag + '>', 'i'); const x = r.exec(b); return x ? x[1].replace(/<[^>]*>/g,'').trim() : ''; };\n        const titel = ex('title'); const desc = ex('description'); const source = ex('source');\n        if (titel && titel.length > 10) results.push({ titel, inhalt: (desc||titel).substring(0,400), quelleDetail: (source||'News') + ' (' + ns.label + ')', typ: 'news' });\n      }\n    }\n  } catch(e) {}\n  await new Promise(r => setTimeout(r, 400));\n}\nconsole.log('Nach News: ' + results.length);\nreturn [{ json: { ...config, alleResults: results } }];"
