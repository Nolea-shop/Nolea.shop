    23|        "jsCode": "// 🏘️ SCHRITT 2: Subreddit Crawler — liest vorherigen Output, APPENDED zu alleResults\nconst prev = $input.first().json;\nconst config = prev;\nconst results = [...(prev.alleResults || [])];\nfor (const sub of config.subreddits) {\n  try {\n    const res = await this.helpers.httpRequest({\n      method: 'GET',\n      url: 'https://www.reddit.com/r/' + sub.name + '/' + sub.sort + '.rss?limit=25',\n      timeout: 12000,\n      headers: { 'User-Agent': 'n8n-deepsearch/3.0' }\n    });\n    const xml = typeof res === 'string' ? res : '';\n    if (xml.length > 100) {\n      const rx = /<entry>([\\s\\S]*?)<\\/entry>/g; let m;\n      while ((m = rx.exec(xml)) !== null) {\n        const b = m[1];\n        const ex = (tag) => { const r = new RegExp('<' + tag + '[^>]*>([\\\\s\\\\S]*?)</' + tag + '>', 'i'); const x = r.exec(b); return x ? x[1].replace(/<[^>]*>/g,'').replace(/&amp;/g,'&').trim() : ''; };\n        const titel = ex('title'); const inhalt = ex('content') || ex('summary');\n        if (titel && titel.length > 5) results.push({ titel, inhalt: inhalt.substring(0,600), quelleDetail: 'r/' + sub.name, typ: 'subreddit' });\n      }\n    }\n  } catch(e) {}\n  await new Promise(r => setTimeout(r, 500));\n}\nconsole.log('Nach Subreddits: ' + results.length);\nreturn [{ json: { ...config, alleResults: results } }];"
